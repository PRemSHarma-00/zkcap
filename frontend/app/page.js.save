              </span>
              
              <div className={`flex items-center gap-1.5 text-[13px] font-normal ${isLightMode ? 'text-gray-600' : 'text-zinc-400'}`}>
                <Clock className="w-3.5 h-3.5" />
                <span>{londonTime || '22:00'} in London</span>
              </div>

              {/* Theme Toggle integrated elegantly inside navigation frame */}
              <button
                onClick={() => setIsLightMode(!isLightMode)}
                className={`p-2 rounded-full border transition-all duration-300 flex items-center justify-center ${
                  isLightMode ? 'bg-zinc-100 border-zinc-200 text-zinc-700 hover:bg-zinc-200' : 'bg-zinc-800 border-zinc-700 text-amber-400 hover:bg-zinc-700'
                }`}
              >
                {isLightMode ? (
                  <svg className="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}><path strokeLinecap="round" strokeLinejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
                ) : (
                  <svg className="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}><path strokeLinecap="round" strokeLinejoin="round" d="M12 3v2.25m0 13.5V21m8.966-8.966h-2.25m-13.5 0h-2.25m15.056-5.056-1.591 1.591M6.536 17.464l-1.591 1.591m12.728 0-1.591-1.591M6.536 6.536 4.945 4.945M12 8.25a3.75 3.75 0 1 0 0 7.5 3.75 3.75 0 0 0 0-7.5Z" /></svg>
                )}
              </button>

              {/* Roll Animation CTA Action */}
              <Link href="/dashboard" className="group flex items-center gap-3 bg-gray-900 dark:bg-zinc-100 text-white dark:text-gray-900 text-[13px] font-medium rounded-full pl-5 pr-2 py-2 transition-transform active:scale-[0.98]">
                <div className="flex flex-col overflow-hidden h-[20px] relative">
                  <span className="transform group-hover:-translate-y-full transition-transform duration-500 ease-custom">
                    Open Dashboard
                  </span>
                  <span className="absolute top-0 left-0 transform translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-custom">
                    Open Dashboard
                  </span>
                </div>
                <div className="w-6 h-6 bg-white dark:bg-gray-900 rounded-full flex items-center justify-center transform group-hover:rotate-[-45deg] transition-transform duration-500 ease-custom">
                  <ArrowRight className="w-3.5 h-3.5 text-gray-900 dark:text-white" />
                </div>
              </Link>
            </div>

            {/* MOBILE NAVIGATION TRIGGER */}
            <div className="flex md:hidden items-center gap-2 pr-1">
              <button
                onClick={() => setIsLightMode(!isLightMode)}
                className={`p-2 rounded-full border transition-all duration-300 ${
                  isLightMode ? 'bg-zinc-100 border-zinc-200 text-zinc-700' : 'bg-zinc-800 border-zinc-700 text-amber-400'
                }`}
              >
                {isLightMode ? (
                  <svg className="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}><path strokeLinecap="round" strokeLinejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
                ) : (
                  <svg className="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2.5}><path strokeLinecap="round" strokeLinejoin="round" d="M12 3v2.25m0 13.5V21m8.966-8.966h-2.25m-13.5 0h-2.25m15.056-5.056-1.591 1.591M6.536 17.464l-1.591 1.591m12.728 0-1.591-1.591M6.536 6.536 4.945 4.945M12 8.25a3.75 3.75 0 1 0 0 7.5 3.75 3.75 0 0 0 0-7.5Z" /></svg>
                )}
              </button>
              
              <button 
                onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
                className="w-9 h-9 sm:w-10 sm:h-10 bg-gray-900 dark:bg-zinc-100 rounded-full flex items-center justify-center text-white dark:text-gray-900 transition-transform active:scale-95"
              >
                {isMobileMenuOpen ? <X className="w-4 h-4" /> : <Menu className="w-4 h-4" />}
              </button>
            </div>
          </nav>

          {/* Spacer forcing layout items down gracefully to the viewport bottom */}
          <div className="flex-1" />

          {/* EDITORIAL HERO TEXT CONTENT CONTEXT LAYER */}
          <div className="w-full px-3 sm:px-8 lg:px-12 pb-14 sm:pb-16 lg:pb-20 flex flex-col items-start">
            
            {/* Top context sublabel */}
            <span className={`text-[13px] sm:text-[14px] font-normal tracking-wide uppercase mb-5 sm:mb-8 ${
              isLightMode ? 'text-gray-900' : 'text-zinc-400'
            }`}>
              Verifiable Commit Attestation Protocol
            </span>
            
            {/* Main Typographic Pitch Block */}
            <h1 className="text-[clamp(1.75rem,7vw,4.2rem)] sm:text-[clamp(2.5rem,5vw,4.2rem)] font-medium leading-[1.08] tracking-[-0.03em] max-w-5xl">
              Your Code Commits. <br className="hidden sm:block" />
              <span className="sm:hidden"> </span>
              Figure It Out Once. <br className="hidden sm:block" />
              <span className="sm:hidden"> </span>
              <span className={isLightMode ? 'text-gray-400' : 'text-zinc-500'}>After That, It Just Runs.</span>
            </h1>

            {/* Product Narrative Subtitle Paragraph */}
            <p className={`text-sm sm:text-base leading-relaxed mt-6 max-w-xl ${
              isLightMode ? 'text-gray-600' : 'text-zinc-400'
            }`}>
              zkCAP is a zero-trust commit attestation protocol combining Phala TEE execution vaults, Midnight zero-knowledge provers, and decentralized ledger state to audit, evaluate, and anchor your codebase without exposing sensitive IP.
            </p>
            
            {/* CTA ACTION PACK ROW */}
            <div className="mt-8 sm:mt-12 flex flex-col sm:flex-row items-stretch sm:items-center gap-4 sm:gap-5 w-full sm:w-auto">
              
              {/* Vibrant Brand Action Button (#F26522) */}
              <Link href="/terminal" className="group flex items-center justify-between sm:justify-start gap-4 bg-[#F26522] hover:bg-[#e05a1a] text-white text-[13px] sm:text-[14px] font-medium rounded-full pl-5 sm:pl-6 pr-2 py-2 transition-all duration-300 shadow-sm active:scale-[0.99]">
                <div className="flex flex-col overflow-hidden h-[20px] relative">
                  <span className="transform group-hover:-translate-y-full transition-transform duration-500 ease-custom">
                    Launch Interactive Terminal
                  </span>
                  <span className="absolute top-0 left-0 transform translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-custom">
                    Launch Interactive Terminal
                  </span>
                </div>
                <div className="w-7 h-7 sm:w-8 sm:h-8 bg-white rounded-full flex items-center justify-center transform group-hover:rotate-[-45deg] transition-transform duration-500 ease-custom">
                  <ArrowRight className="w-4 h-4 text-[#F26522]" />
                </div>
              </Link>
              
              {/* Premium Shadow Partner Badge Component */}
              <div className={`flex items-center justify-between gap-3 px-4 py-2 rounded-[4px] border transition-all duration-500 shadow-[0_2px_8px_rgba(0,0,0,0.08)] hover:shadow-[0_4px_16px_rgba(0,0,0,0.12)] ${
                isLightMode ? 'bg-white border-zinc-200/50' : 'bg-zinc-900 border-zinc-800'
              }`}>
                <div className="flex items-center gap-2">
                  <svg className="w-5 h-5 sm:w-6 sm:h-6 fill-current text-[#E8704E]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
                    <path d={starburstSvgPath} />
                  </svg>
                  <span className={`text-[13px] sm:text-[14px] font-medium ${isLightMode ? 'text-gray-900' : 'text-zinc-200'}`}>
                    TEE & ZK Secured
                  </span>
                </div>
                <span className="text-[10px] sm:text-[11px] font-bold uppercase tracking-wider bg-gray-900 dark:bg-zinc-100 text-white dark:text-gray-900 px-1.5 sm:px-2 py-0.5 rounded">
                  Active
                </span>
              </div>

            </div>

          </div>
        </section>

        {/* ========================================== */}
        {/* MOBILE OVERLAY DRAWER BOTTOM SHEET PANEL   */}
        {/* ========================================== */}
        <div className={`fixed inset-0 z-50 transition-opacity duration-500 bg-black/60 backdrop-blur-sm md:hidden ${
          isMobileMenuOpen ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'
        }`}>
          <div className={`absolute bottom-0 left-0 right-0 mx-3 mb-3 p-6 rounded-2xl bg-white dark:bg-zinc-900 border dark:border-zinc-800 transform transition-transform duration-500 ease-sheet ${
            isMobileMenuOpen ? 'translate-y-0' : 'translate-y-full'
          }`}>
            <div className="flex items-center justify-between mb-8">
              <div className="flex items-center gap-2 text-xs text-gray-500 dark:text-zinc-400 bg-gray-100 dark:bg-zinc-800 px-3 py-1 rounded-full">
                <Clock className="w-3 h-3" />
                <span>{londonTime || '22:00'} London Time</span>
              </div>
              <button 
                onClick={() => setIsMobileMenuOpen(false)}
                className="w-8 h-8 rounded-full bg-gray-100 dark:bg-zinc-800 flex items-center justify-center text-gray-900 dark:text-zinc-100"
