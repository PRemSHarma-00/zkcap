'use client';

import { useState, useEffect } from 'react';
import Link from 'next/link';
import { ArrowRight, Clock, Menu, X } from 'lucide-react';

export default function Home() {
  const [isLightMode, setIsLightMode] = useState(true);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [londonTime, setLondonTime] = useState('');

  // Live London Time Sync (Format: HH:MM)
  useEffect(() => {
    const updateTime = () => {
      const options = {
        timeZone: 'Europe/London',
        hour: '2xl-digit',
        minute: '2xl-digit',
        hour12: false,
      };
      const formatter = new Intl.DateTimeFormat('en-GB', options);
      setLondonTime(formatter.format(new Date()));
    };

    updateTime();
    const interval = setInterval(updateTime, 1000);
    return () => clearInterval(interval);
  }, []);

  // Starburst/Compass SVG Path for the Partner Badge
  const starburstSvgPath = "m19.6 66.5 19.7-11 .3-1-.3-.5h-1l-3.3-.2-11.2-.3L14 53l-9.5-.5-2.4-.5L0 49l.2-1.5 2-1.3 2.9.2 6.3.5 9.5.6 6.9.4L38 49.1h1.6l.2-.7-.5-.4-.4-.4L29 41l-10.6-7-5.6-4.1-3-2-1.5-2-.6-4.2 2.7-3 3.7.3.9.2 3.7 2.9 8 6.1L37 36l1.5 1.2.6-.4.1-.3-.7-1.1L33 25l-6-10.4-2.7-4.3-.7-2.6c-.3-1-.4-2-.4-3l3-4.2L28 0l4.2.6L33.8 2l2.6 6 4.1 9.3L47 29.9l2 3.8 1 3.4.3 1h.7v-.5l.5-7.2 1-8.7 1-11.2.3-3.2 1.6-3.8 3-2L61 2.6l2 2.9-.3 1.8-1.1 7.7L59 27.1l-1.5 8.2h.9l1-1.1 4.1-5.4 6.9-8.6 3-3.5L77 13l2.3-1.8h4.3l3.1 4.7-1.4 4.9-4.4 5.6-3.7 4.7-5.3 7.1-3.2 5.7.3.4h.7l12-2.6 6.4-1.1 7.6-1.3 3.5 1.6.4 1.6-1.4 3.4-8.2 2-9.6 2-14.3 3.3-.2.1.2.3 6.4.6 2.8.2h6.8l12.6 1 3.3 2 1.9 2.7-.3 2-5.1 2.6-6.8-1.6-16-3.8-5.4-1.3h-.8v.4l4.6 4.5 8.3 7.5L89 80.1l.5 2.4-1.3 2-1.4-.2-9.2-7-3.6-3-8-6.8h-.5v.7l1.8 2.7 9.8 14.7.5 4.5-.7 1.4-2.6 1-2.7-.6-5.8-8-6-9-4.7-8.2-.5.4-2.9 30.2-1.3 1.5-3 1.2-2.5-2-1.4-3 1.4-6.2 1.6-8 1.3-6.4 1.2-7.9.7-2.6v-.2H49L43 72l-9 12.3-7.2 7.6-1.7.7-3-1.5.3-2.8L24 86l10-12.8 6-7.9 4-4.6-.1-.5h-.3L17.2 77.4l-4.7.6-2-2 .2-3 1-1 8-5.5Z";

  return (
    <>
      {/* Global CSS Utilities for Liquid Glass Simulation */}
      <style jsx global>{`
        .liquid-glass {
          background: rgba(255, 255, 255, 0.01);
          backdrop-filter: blur(4px);
          box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.05);
        }
        .liquid-glass-strong {
          background: rgba(255, 255, 255, 0.01);
          backdrop-filter: blur(50px);
        }
        .ease-custom {
          transition-timing-function: cubic-bezier(0.25, 0.1, 0.25, 1);
        }
        .ease-sheet {
          transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
        }
      `}</style>

      <div className={`relative min-h-screen w-full transition-colors duration-500 overflow-x-hidden ${
        isLightMode ? 'bg-[#EFEFEF] text-gray-900' : 'bg-[#0e0e11] text-zinc-100'
      }`}>
        
        {/* ========================================== */}
        {/* BACKGROUND LAYER: FULL-SCREEN ANIMATED SHADER */}
        {/* ========================================== */}
        <div className="absolute inset-0 z-10 pointer-events-none overflow-hidden select-none">
          {/* 
            Shader Package Stack Reference Configuration:
            <Shader>
              <Swirl colorA="#ffffff" colorB="#f0f0f0" detail={1.7} />
              <ChromaFlow baseColor="#ffffff" downColor="#ff5f03" leftColor="#ff5f03" rightColor="#ff5f03" upColor="#ff5f03" momentum={13} radius={3.5} />
              <FlutedGlass aberration={0.61} angle={31} frequency={8} highlight={0.12} highlightSoftness={0} lightAngle={-90} refraction={4} shape="rounded" softness={1} speed={0.15} />
              <FilmGrain strength={0.05} />
            </Shader>
          */}
          <div className={`absolute inset-0 w-full h-full mix-blend-multiply opacity-85 transition-opacity duration-500 ${
            isLightMode ? 'bg-gradient-to-tr from-white via-zinc-100 to-orange-50/40' : 'bg-gradient-to-tr from-zinc-900 via-zinc-950 to-orange-950/20'
          }`} />
          
          {/* Simulated Organic ChromaFlow Liquid Wave Formations */}
          <div className="absolute top-[-20%] right-[-10%] w-[80vw] h-[80vw] rounded-full blur-[140px] mix-blend-screen opacity-25 bg-[#ff5f03] animate-pulse" style={{ animationDuration: '8s' }} />
          <div className="absolute bottom-[-30%] left-[-10%] w-[70vw] h-[70vw] rounded-full blur-[160px] mix-blend-screen opacity-15 bg-orange-600" style={{ animationDuration: '12s' }} />
          
          {/* Subtle Fluted Glass Overlay Effect */}
          <div className="absolute inset-0 w-full h-full opacity-[0.04] pointer-events-none repeating-linear-gradient"
               style={{ backgroundImage: 'repeating-linear-gradient(90deg, transparent, transparent 4px, #000 4px, #000 8px)' }} />
               
          {/* Film Grain Strength Layer simulation */}
          <div className="absolute inset-0 w-full h-full opacity-[0.015] pointer-events-none"
               style={{ backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E")` }} />
        </div>

        {/* ========================================== */}
        {/* SECTION 1: HERO VIEWPORT CONTAINER         */}
        {/* ========================================== */}
        <section className="relative z-20 min-h-screen w-full flex flex-col justify-between p-2 sm:p-3 max-w-[1440px] mx-auto">
          
          {/* TOP NAVIGATION PILL CONTAINER */}
          <nav className={`w-full rounded-full p-1.5 flex items-center justify-between transition-all duration-500 shadow-sm border ${
            isLightMode 
              ? 'bg-white border-zinc-200/60 shadow-zinc-200/40' 
              : 'bg-zinc-900/90 border-zinc-800/80 shadow-black/40'
          }`}>
            
            {/* LEFT: Branding & Core Interactive Links */}
            <div className="flex items-center gap-6 pl-1.5">
              <Link href="/" className="w-9 h-9 sm:w-10 sm:h-10 bg-gray-900 dark:bg-zinc-100 rounded-full flex items-center justify-center transition-transform hover:scale-105 active:scale-95">
                <span className="text-[10px] sm:text-[11px] font-bold tracking-tight text-white dark:text-gray-900">ZK</span>
              </Link>
              
              <div className="hidden md:flex items-center gap-6">
                {['Terminal', 'Projects', 'Attestations', 'Commits', 'Prover (ZK)'].map((link) => (
                  <Link 
                    key={link} 
                    href={`/${link.toLowerCase().replace(/[^a-z]/g, '')}`} 
                    className={`text-[14px] font-normal transition-colors duration-300 ${
                      isLightMode ? 'text-gray-900 hover:text-gray-500' : 'text-zinc-300 hover:text-zinc-500'
