              </div>
            </div>
            
            {/* RIGHT: Operational Context Details & Primary Action */}
            <div className="hidden md:flex items-center gap-5 pr-1.5">
              <span className={`text-[13px] hidden lg:inline-block font-normal ${isLightMode ? 'text-gray-600' : 'text-zinc-400'}`}>
