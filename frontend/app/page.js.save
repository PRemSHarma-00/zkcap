                  href={`/${link.toLowerCase().replace(/[^a-z]/g, '')}`}
                  onClick={() => setIsMobileMenuOpen(false)}
                  className="text-[28px] sm:text-[32px] font-medium text-gray-900 dark:text-white hover:text-gray-500 transition-colors"
                >
                  {link}
                </Link>
              ))}
            </div>

            <Link 
              href="/terminal"
              onClick={() => setIsMobileMenuOpen(false)}
              className="w-full flex items-center justify-between bg-[#F26522] text-white p-4 rounded-xl text-base font-medium"
            >
              <span>Launch Interactive Terminal</span>
              <ArrowRight className="w-5 h-5" />
            </Link>
          </div>
        </div>

      </div>
    </>
  );
}
